# Copy to .env and adjust (optional — defaults work for local dev)

# SQLite is used when Postgres is unavailable. To force SQLite only, set:
# DATABASE_URL=sqlite:///./data/anti_gravity.db

# Upload workspace (created automatically)
UPLOAD_DIR=./data/uploads

# Browser URL for deployed copies of this platform (previews call this API)
ORCHESTRATOR_PUBLIC_API_URL=http://localhost:8000
